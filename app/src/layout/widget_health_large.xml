<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background_medium"
    android:padding="12dp">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <RelativeLayout
            android:layout_width="100dp"
            android:layout_height="75dp">

            <ImageView
                android:id="@+id/img_health_arc"
                android:layout_width="100dp"
                android:layout_height="75dp"
                android:contentDescription="@null"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/txt_health_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="6dp"
                android:text="--"
                android:textColor="@color/widget_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_health_score"
                android:textColor="@color/widget_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_score_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready for today's check?"
                android:textColor="@color/widget_text_secondary"
                android:textSize="12sp" />
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                
                <View
                    android:id="@+id/status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/widget_circle_bg" />
                    
                <TextView
                    android:id="@+id/txt_last_sync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Synced: Just now"
                    android:textColor="@color/widget_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Metrics Grid (Upper Row) -->
    <LinearLayout
        android:id="@+id/metrics_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header_container"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <include
            android:id="@+id/btn_bmi"
            layout="@layout/layout_widget_nav_button" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/btn_bp"
            layout="@layout/layout_widget_nav_button" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/btn_water"
            layout="@layout/layout_widget_nav_button" />
    </LinearLayout>

    <!-- Metrics Grid (Lower Row) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/metrics_row_1"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <include
            android:id="@+id/btn_calories"
            layout="@layout/layout_widget_nav_button" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/btn_weight"
            layout="@layout/layout_widget_nav_button" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <include
            android:id="@+id/btn_streak"
            layout="@layout/layout_widget_nav_button" />
    </LinearLayout>

</RelativeLayout>
