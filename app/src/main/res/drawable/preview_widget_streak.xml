<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF8F6" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#FFCCBC" />
        </shape>
    </item>

    <!-- Left accent circle (fire) -->
    <item android:left="10dp" android:top="10dp" android:right="130dp" android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#FFEBEE" />
        </shape>
    </item>

    <!-- Progress bar (streak) -->
    <item android:left="80dp" android:top="50dp" android:right="14dp" android:bottom="52dp">
        <shape android:shape="rectangle">
            <solid android:color="#FF9800" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>
