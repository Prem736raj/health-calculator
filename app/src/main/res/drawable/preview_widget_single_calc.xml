<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F8FFFE" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#E3EDF7" />
        </shape>
    </item>

    <!-- Icon circle -->
    <item android:left="10dp" android:top="10dp" android:right="130dp" android:bottom="10dp">
        <shape android:shape="oval">
            <solid android:color="#E3F2FD" />
        </shape>
    </item>

    <!-- Result text placeholder -->
    <item android:left="80dp" android:top="20dp" android:right="40dp" android:bottom="44dp">
        <shape android:shape="rectangle">
            <solid android:color="#BBDEFB" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Subtitle text placeholder -->
    <item android:left="80dp" android:top="44dp" android:right="70dp" android:bottom="26dp">
        <shape android:shape="rectangle">
            <solid android:color="#E3F2FD" />
            <corners android:radius="3dp" />
        </shape>
    </item>

</layer-list>
