<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background_medium">

    <!-- Left: Large Progress Ring -->
    <FrameLayout
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="center_vertical">

        <ImageView
            android:id="@+id/medium_progress_bg"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/widget_circle_bg_large"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/medium_progress_arc"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:contentDescription="@null" />

        <!-- Center Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_water_drop_widget"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/medium_intake_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0L"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"
                android:maxLines="1" />

            <TextView
                android:id="@+id/medium_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="9sp"
                android:textColor="@color/widget_water_blue"
                android:maxLines="1" />

        </LinearLayout>
    </FrameLayout>

    <!-- Right Panel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:gravity="center_vertical">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💧 Water Intake"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />

        </LinearLayout>

        <!-- Progress Text -->
        <TextView
            android:id="@+id/medium_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0L / 2.5L"
            android:textSize="11sp"
            android:textColor="@color/widget_water_blue"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <!-- Glasses Count -->
        <TextView
            android:id="@+id/medium_glasses_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🥛 0 glasses"
            android:textSize="10sp"
            android:textColor="@color/widget_text_secondary"
            android:layout_marginTop="2dp" />

        <!-- Last Logged Time -->
        <TextView
            android:id="@+id/medium_last_logged"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏰ Not logged today"
            android:textSize="9sp"
            android:textColor="@color/widget_text_secondary"
            android:layout_marginTop="2dp" />

        <!-- Quick Add Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="start">

            <!-- +Glass Button -->
            <TextView
                android:id="@+id/btn_add_glass"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="+Glass"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/widget_btn_text"
                android:background="@drawable/widget_btn_blue"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- +Bottle Button -->
            <TextView
                android:id="@+id/btn_add_bottle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="+Bottle"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/widget_btn_text"
                android:background="@drawable/widget_btn_blue_outline"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
