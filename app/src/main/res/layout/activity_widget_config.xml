<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/config_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ Quick Calculate Widget"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/config_text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose your 4 calculator shortcuts"
            android:textSize="13sp"
            android:textColor="@color/config_text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Section: Calculator Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CALCULATOR SHORTCUTS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/config_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- Slot 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/config_item_bg"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Slot 1"
                android:textSize="14sp"
                android:textColor="@color/config_text_primary" />

            <Spinner
                android:id="@+id/spinner_slot_1"
                android:layout_width="160dp"
                android:layout_height="36dp"
                android:background="@drawable/config_spinner_bg" />

        </LinearLayout>

        <!-- Slot 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/config_item_bg"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Slot 2"
                android:textSize="14sp"
                android:textColor="@color/config_text_primary" />

            <Spinner
                android:id="@+id/spinner_slot_2"
                android:layout_width="160dp"
                android:layout_height="36dp"
                android:background="@drawable/config_spinner_bg" />

        </LinearLayout>

        <!-- Slot 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/config_item_bg"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Slot 3"
                android:textSize="14sp"
                android:textColor="@color/config_text_primary" />

            <Spinner
                android:id="@+id/spinner_slot_3"
                android:layout_width="160dp"
                android:layout_height="36dp"
                android:background="@drawable/config_spinner_bg" />

        </LinearLayout>

        <!-- Slot 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/config_item_bg"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Slot 4"
                android:textSize="14sp"
                android:textColor="@color/config_text_primary" />

            <Spinner
                android:id="@+id/spinner_slot_4"
                android:layout_width="160dp"
                android:layout_height="36dp"
                android:background="@drawable/config_spinner_bg" />

        </LinearLayout>

        <!-- Section: Theme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WIDGET THEME"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/config_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <!-- Theme Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <!-- Light -->
            <LinearLayout
                android:id="@+id/theme_light"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="6dp"
                android:background="@drawable/config_theme_card_light"
                android:padding="8dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="28dp"
                    android:background="@drawable/config_theme_preview_light" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Light"
                    android:textSize="11sp"
                    android:textColor="#1A237E"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Dark -->
            <LinearLayout
                android:id="@+id/theme_dark"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/config_theme_card_dark"
                android:padding="8dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="28dp"
                    android:background="@drawable/config_theme_preview_dark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dark"
                    android:textSize="11sp"
                    android:textColor="#E3F2FD"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Transparent -->
            <LinearLayout
                android:id="@+id/theme_transparent"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:background="@drawable/config_theme_card_transparent"
                android:padding="8dp">

                <View
                    android:layout_width="40dp"
                    android:layout_height="28dp"
                    android:background="@drawable/config_theme_preview_transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:textSize="11sp"
                    android:textColor="@color/config_text_primary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Section: Opacity -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BACKGROUND OPACITY"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/config_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <SeekBar
                android:id="@+id/seekbar_opacity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/config_accent"
                android:thumbTint="@color/config_accent" />

            <TextView
                android:id="@+id/opacity_label"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textSize="12sp"
                android:textColor="@color/config_text_primary"
                android:gravity="end"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Widget Preview -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREVIEW"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/config_accent"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/config_preview_frame">

            <include
                android:id="@+id/widget_preview_include"
                layout="@layout/widget_quick_calculate"
                android:layout_width="160dp"
                android:layout_height="120dp"
                android:layout_gravity="center" />

        </FrameLayout>

        <!-- Add Widget Button -->
        <Button
            android:id="@+id/btn_add_widget"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Add Widget"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/config_btn_add"
            android:layout_marginBottom="12dp" />

        <!-- Cancel -->
        <Button
            android:id="@+id/btn_cancel_config"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="@color/config_text_secondary"
            android:background="@android:color/transparent" />

    </LinearLayout>

</ScrollView>
