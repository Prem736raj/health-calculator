<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background_small">

    <!-- Circular Progress Container -->
    <FrameLayout
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_vertical">

        <!-- Background Circle -->
        <ImageView
            android:id="@+id/small_progress_bg"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/widget_circle_bg"
            android:contentDescription="@null" />

        <!-- Progress Arc (drawn via RemoteViews bitmap) -->
        <ImageView
            android:id="@+id/small_progress_arc"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:contentDescription="@null" />

        <!-- Center Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/small_intake_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0L"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary"
                android:maxLines="1" />

            <TextView
                android:id="@+id/small_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="8sp"
                android:textColor="@color/widget_text_secondary"
                android:maxLines="1" />

        </LinearLayout>
    </FrameLayout>

    <!-- Right Info Panel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="8dp">

        <TextView
            android:id="@+id/small_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 Water"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary" />

        <TextView
            android:id="@+id/small_goal_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Goal: 2.5L"
            android:textSize="9sp"
            android:textColor="@color/widget_text_secondary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>
